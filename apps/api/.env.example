# Watchpost API — environment variables
# Copy this file to .env and fill in the values you need.
# None of these are required to run the app — they unlock optional features.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# Allowed frontend origin. In production set this to your Vercel URL.
# Comma-separated list accepted: https://app.vercel.app,https://yourdomain.com
CORS_ORIGIN=http://localhost:5173

# Directory where the SQLite database is stored (scan cache + monitors).
# On Railway: set this to the mount path of a persistent volume (e.g. /data).
# Defaults to apps/api/data/ when unset.
DATA_DIR=/data

# ── Email alerts (Monitor module) ─────────────────────────────────────────────
# Required to send email alerts when a monitored site's score drops below threshold.
# Works with any SMTP provider: Gmail, Outlook, Brevo, Resend SMTP, Mailgun…
#
# Gmail example (use an App Password, not your main password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx-xxxx-xxxx-xxxx
#
# Brevo (free — 300 emails/day, no credit card):
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=your-brevo-login@example.com
#   SMTP_PASS=your-brevo-smtp-key

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Watchpost Alerts <noreply@yourdomain.com>
