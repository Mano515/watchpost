{
  "name": "@watchpost/api",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "prebuild": "npm run build --workspace=@watchpost/shared-types",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/zxcvbn": "^4.4.5",
    "@watchpost/shared-types": "*",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "nodemailer": "^9.0.1",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^8.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
