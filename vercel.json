{
  "buildCommand": "npm run build --workspace=@watchpost/shared-types && cd apps/web && npx vite build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm ci",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://watchpostapi-production.up.railway.app/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
